/* 目标一: 报告页顶部 IP 图 */
.beast-ip-hero {
  width: 100%;
  position: relative;
  background: transparent;
  /* 给底部羽化区留出呼吸空间，避免内容遮挡 */
  margin-bottom: -12px;
}
.beast-ip-img {
  width: 100%;
  display: block;
  object-fit: contain;
  max-height: 320px;

  /*
   * 羽化融合：用椭圆径向渐变 mask，中心区域完全不透明，
   * 向四周尤其底部和左右逐渐透明，像印在宣纸上自然消隐。
   *
   * 椭圆参数：108% × 125%（宽超出元素确保侧边够宽）
   * 中心偏上（22%），使底部衰减更早、更自然。
   */
  /*
   * 双线性渐变交叉 mask（intersect = 两个方向同时羽化）：
   *   第一层：上下方向 —— 底部从 50% 开始淡出，93% 完全透明
   *   第二层：左右方向 —— 两侧各 14% 宽的淡入/淡出区
   * 两层 alpha 相乘，确保四边都有效羽化，不再依赖椭圆半径估算。
   */
  -webkit-mask-image:
    linear-gradient(to bottom,
      rgba(0, 0, 0, 0.7)   0%,
      black                 4%,
      black                50%,
      rgba(0, 0, 0, 0.88)  62%,
      rgba(0, 0, 0, 0.55)  75%,
      rgba(0, 0, 0, 0.15)  86%,
      transparent          94%
    ),
    linear-gradient(to right,
      transparent           0%,
      rgba(0, 0, 0, 0.35)   5%,
      rgba(0, 0, 0, 0.80)  10%,
      black                15%,
      black                85%,
      rgba(0, 0, 0, 0.80)  90%,
      rgba(0, 0, 0, 0.35)  95%,
      transparent          100%
    );
  -webkit-mask-composite: source-in;

  mask-image:
    linear-gradient(to bottom,
      rgba(0, 0, 0, 0.7)   0%,
      black                 4%,
      black                50%,
      rgba(0, 0, 0, 0.88)  62%,
      rgba(0, 0, 0, 0.55)  75%,
      rgba(0, 0, 0, 0.15)  86%,
      transparent          94%
    ),
    linear-gradient(to right,
      transparent           0%,
      rgba(0, 0, 0, 0.35)   5%,
      rgba(0, 0, 0, 0.80)  10%,
      black                15%,
      black                85%,
      rgba(0, 0, 0, 0.80)  90%,
      rgba(0, 0, 0, 0.35)  95%,
      transparent          100%
    );
  mask-composite: intersect;
}
.beast-ip-caption {
  position: relative;   /* 确保 caption 在 mask 之外，不受影响 */
  z-index: 1;
  text-align: center;
  font-size: 13px;
  color: #8b7355;
  padding: 4px 0 2px;
  letter-spacing: 3px;
}

/* 目标二: 翻转卡片覆盖层 */
#flip-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.25s;
}
#flip-overlay.visible {
  opacity: 1;
}
.flip-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(6px);
}
.flip-scene {
  position: relative;
  z-index: 1;
  width: 300px;
  height: 420px;
  perspective: 1200px;
  cursor: pointer;
  user-select: none;
}
.flip-card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 16px;
}
.flip-card-inner.flipped {
  transform: rotateY(180deg);
}
.flip-front,
.flip-back {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 16px;
  overflow: hidden;
}
.flip-front {
  background: linear-gradient(155deg, #1c3028 0%, #0d1e18 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32px 28px;
  color: #e8d9c0;
  border: 1px solid rgba(168, 143, 89, 0.35);
}
.flip-beast-name {
  font-size: 34px;
  font-weight: 700;
  letter-spacing: 6px;
  color: #c9a96e;
  margin-bottom: 18px;
}
.flip-primary {
  font-size: 16px;
  letter-spacing: 2px;
  color: #e8d9c0;
  margin-bottom: 6px;
}
.flip-sub {
  font-size: 13px;
  color: #a89070;
  margin-bottom: 20px;
  letter-spacing: 1px;
}
.flip-quote {
  font-size: 13px;
  color: #b0a090;
  text-align: center;
  line-height: 1.9;
  border-top: 1px solid rgba(168, 143, 89, 0.25);
  padding-top: 16px;
  width: 100%;
}
.flip-hint {
  margin-top: 20px;
  font-size: 11px;
  color: rgba(200, 180, 140, 0.45);
  letter-spacing: 2px;
}
.flip-back {
  transform: rotateY(180deg);
}
.flip-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.flip-back-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.72) 0%, rgba(0, 0, 0, 0.08) 55%);
}
.flip-enter-btn {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(201, 169, 110, 0.92);
  color: #1a1205;
  border: none;
  border-radius: 24px;
  padding: 12px 32px;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 3px;
  cursor: pointer;
  white-space: nowrap;
  -webkit-tap-highlight-color: transparent;
}
.flip-enter-btn:active {
  opacity: 0.8;
}

/* 目标三: 五行世界背景 */
.world-bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 100%;
  background-size: cover;
  background-position: center top;
  z-index: 0;
  pointer-events: none;
}
.world-bg-layer::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(245, 240, 232, 0.83);
}
.world-screen-inner.world-has-bg {
  position: relative;
}
.world-screen-inner.world-has-bg > *:not(.world-bg-layer) {
  position: relative;
  z-index: 1;
}
