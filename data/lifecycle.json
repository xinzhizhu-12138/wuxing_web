  "special_phase_definitions": {
    "寄行": {
      "modern_name": "借势期",
      "energy_level": "过渡",
      "title": "借一个位置慢慢成形",
      "text": "土在此处不是直接盛放，而是借环境运行。适合借助外部结构，把自己慢慢安放好。",
      "advice": "先借势，不急着独自承担全部。"
    },
    "衰病": {
      "modern_name": "修整期",
      "energy_level": "回落",
      "title": "把承载过的重量放一放",
      "text": "土在此处同时有回落与修复的意味。适合减少负担，重新分配责任。",
      "advice": "不要什么都自己扛，先把边界立回来。"
    }
