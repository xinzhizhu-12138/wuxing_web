{
  "meta": {
    "name": "人生节律",
    "version": "v1",
    "basis": "《五行大義》卷二·第四論相生·二者論生死所",
    "source_id": "WXY-010",
    "usage_note": "用于解释五行能量的周期状态，不用于预测吉凶、寿命、疾病或绝对命运。",
    "calculation_note": "第一版建议按用户主五行与当前月支匹配阶段；若产品不接实时月份，也可作为五行文化解释卡使用。"
  },
  "phase_order": ["受气", "胎", "养", "生", "沐浴", "冠带", "临官", "王", "衰", "病", "死", "葬"],
  "phase_definitions": {
    "受气": {
      "modern_name": "起念期",
      "energy_level": "潜伏",
      "title": "新的气正在回来",
      "text": "这一阶段像一个念头刚刚出现，还没有成形。适合观察、恢复感受力，不急着证明自己。",
      "advice": "先记录灵感和方向，少做过早承诺。"
    },
    "胎": {
      "modern_name": "孕育期",
      "energy_level": "内生",
      "title": "事情还在体内长",
      "text": "这一阶段不是停滞，而是内部结构正在形成。外面看起来不明显，但里面已经开始有了轮廓。",
      "advice": "保护尚未成熟的想法，给它一点安静。"
    },
    "养": {
      "modern_name": "养成期",
      "energy_level": "蓄力",
      "title": "慢慢把自己养起来",
      "text": "这一阶段适合补资源、补耐心、补基础。你可能还没到冲出去的时候，但已经在为之后的展开做准备。",
      "advice": "把基础流程、资料和支持系统先搭好。"
    },
    "生": {
      "modern_name": "萌发期",
      "energy_level": "初起",
      "title": "可以开始露出一点光",
      "text": "这一阶段适合开始行动。它不一定马上成熟，但已经可以从想法进入现实。",
      "advice": "先做一个小版本，不必一开始就完整。"
    },
    "沐浴": {
      "modern_name": "试水期",
      "energy_level": "流动",
      "title": "在变化里找到手感",
      "text": "这一阶段容易敏感、摇摆，也容易产生新鲜感。它适合体验、调整、试错，而不是立刻定型。",
      "advice": "允许自己试一试，但不要被每一次反馈牵着走。"
    },
    "冠带": {
      "modern_name": "成形期",
      "energy_level": "上升",
      "title": "开始有了自己的样子",
      "text": "这一阶段适合建立形象、规范和表达方式。你会更清楚自己要以什么姿态出现。",
      "advice": "整理表达、边界和对外呈现。"
    },
    "临官": {
      "modern_name": "上场期",
      "energy_level": "承担",
      "title": "你开始进入自己的位置",
      "text": "这一阶段适合承担角色、进入职能、把能力放到真实场景里使用。",
      "advice": "别只准备，开始接住具体责任。"
    },
    "王": {
      "modern_name": "盛放期",
      "energy_level": "高峰",
      "title": "这是你的高光阶段",
      "text": "这一阶段能量最足，适合推进、表达、定方向，也适合让成果被看见。",
      "advice": "把握窗口，但记得给自己留余地。"
    },
    "衰": {
      "modern_name": "回落期",
      "energy_level": "收束",
      "title": "从高处慢慢收回来",
      "text": "这一阶段不是失败，而是能量从高峰回到整理。适合复盘、筛选、减少消耗。",
      "advice": "少开新局，多做取舍。"
    },
    "病": {
      "modern_name": "修复期",
      "energy_level": "调整",
      "title": "需要照顾被消耗的地方",
      "text": "这一阶段不要理解成疾病，而是提醒你看见失衡、疲惫和过度使用的部分。",
      "advice": "降低强度，优先修复节奏。"
    },
    "死": {
      "modern_name": "归零期",
      "energy_level": "暂停",
      "title": "旧的状态正在结束",
      "text": "这一阶段不是坏事，而是旧模式走到尽头。适合停止无效消耗，承认某些东西需要结束。",
      "advice": "不要硬撑，给结束一个体面的空间。"
    },
    "葬": {
      "modern_name": "蓄藏期",
      "energy_level": "沉潜",
      "title": "把经验埋回土里",
      "text": "这一阶段适合沉淀、归档、消化经验。它看起来安静，却是在为下一轮受气做准备。",
      "advice": "整理旧经验，等待下一次起念。"
    }
  },
